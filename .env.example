# Cloudflare Worker URL for support email (no API keys in app)
EXPO_PUBLIC_SUPPORT_WORKER_URL=https://qr-scanner-support.qr-app.workers.dev

# AdMob app IDs are native config values used by the config plugin.
# Leave blank to use Google's test App IDs in development builds.
ADMOB_ANDROID_APP_ID=
ADMOB_IOS_APP_ID=

# Production ad unit IDs. Development uses Google test IDs automatically.
EXPO_PUBLIC_ADMOB_BANNER_AD_UNIT_ID=
EXPO_PUBLIC_ADMOB_INTERSTITIAL_AD_UNIT_ID=
EXPO_PUBLIC_ADMOB_REWARDED_AD_UNIT_ID=
